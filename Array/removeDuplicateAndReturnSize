// Removes duplicates from sorted array and returns new size
public static int removeDuplicateAndReturnSize(int[] arr) {
    if (arr.length == 0) return 0;

    int i = 0; // points to last unique element

    for (int j = 1; j < arr.length; j++) {
        if (arr[i] != arr[j]) {
            i++;
            arr[i] = arr[j];
        }
    }

    return i + 1;
}
