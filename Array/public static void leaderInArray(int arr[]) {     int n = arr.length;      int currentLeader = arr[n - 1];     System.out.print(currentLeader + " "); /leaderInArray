public static void leaderInArray(int arr[]) {
    int n = arr.length;

    int currentLeader = arr[n - 1];
    System.out.print(currentLeader + " ");
    // print last element

    for (int i = n - 2; i >= 0; i--) {
        if (arr[i] > currentLeader) {
            System.out.print(arr[i] + " ");
            currentLeader = arr[i];
        }
    }
    System.out.println();
}
