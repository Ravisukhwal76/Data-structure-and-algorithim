public static void maxDifference(int arr[]){
    int n = arr.length;  
    int maxDifference = arr[1] - arr[0];
    int min = arr[0];

    for(int i = 1; i < n; i++){
        maxDifference = Math.max(maxDifference, arr[i] - min);
        min = Math.min(min, arr[i]);
    }

    System.out.println(maxDifference);
}
